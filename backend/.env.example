APP_NAME="Filecano API"
DATABASE_URL="postgresql+psycopg://filecano:filecano@localhost:5432/filecano"
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="filecano"
MINIO_SECURE="false"
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
JWT_SECRET_KEY="insert-token-here"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_SECONDS=3600
ACCESS_TOKEN_REFRESH_GRACE_SECONDS=86400
SHARED_URL_EXPIRE_SECONDS=604800
SHARE_TOKEN_LENGTH=8
MAX_FILE_SIZE_BYTES=2147483648
REDIS_URL="redis://:1234@host.docker.internal:6379/0"
CELERY_BROKER_URL="redis://:1234@host.docker.internal:6379/0"
DATA_RETENTION_POLICY=45
AUTH_COOKIE_NAME="filecano_access_token"
AUTH_COOKIE_SECURE="false"
AUTH_COOKIE_SAME_SITE="lax"
AUTH_COOKIE_MAX_AGE=86400
